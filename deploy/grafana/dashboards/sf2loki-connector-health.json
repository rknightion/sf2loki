                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "histogram_quantile(0.95, sum by (le)(rate(sf2loki_ingest_lag_seconds_bucket{job=\"$job\"}[$__rate_interval])))",
