{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "sf2loki-connector-health",
    "annotations": {
      "grafana.app/folder": "sf2loki"
    }
  },
  "spec": {
    "title": "sf2loki \u00b7 Connector Health",
    "description": "Self-observability for the sf2loki connector (OTLP metrics). See header for the metric-suffix requirement.",
    "tags": [
      "sf2loki",
      "connector",
      "health"
    ],
    "editable": true,
    "preload": false,
    "cursorSync": "Off",
    "liveNow": false,
    "links": [],
    "annotations": [],
    "timeSettings": {
      "from": "now-6h",
      "to": "now",
      "timezone": "browser",
      "autoRefresh": "",
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0,
      "autoRefreshIntervals": [
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "1d"
      ]
    },
    "variables": [
      {
        "kind": "CustomVariable",
        "spec": {
          "name": "job",
          "label": "Job",
          "query": "sf2loki",
          "current": {
            "text": "sf2loki",
            "value": "sf2loki"
          },
          "options": [
            {
              "text": "sf2loki",
              "value": "sf2loki",
              "selected": true
            }
          ],
          "hide": "dontHide",
          "multi": false,
          "includeAll": false,
          "allValue": "",
          "skipUrlSync": false,
          "allowCustomValue": true
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "name": "ds_prom",
          "label": "Prometheus datasource",
          "pluginId": "prometheus",
          "current": {
            "text": "",
            "value": ""
          },
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": false,
          "includeAll": false,
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": ""
        }
      }
    ],
    "elements": {
      "hlth-header": {
        "kind": "Panel",
        "spec": {
          "id": 500,
          "title": "",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "text",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "mode": "markdown",
                "content": "## sf2loki Connector Health\nThe connector's own self-observability, exported via **OTLP metrics** (no scrape endpoint).\n\n> **Metric name suffixes (important):** instruments are created unsuffixed (e.g. `sf2loki_events_ingested`), but they appear in Prometheus/Grafana with the OTel Prometheus suffixes `_total` / `_bucket` / `_count` / `_sum` \u2014 every query below relies on that. Grafana Cloud's OTLP endpoint adds these by default; if you route through your own Collector/Alloy, keep `add_metric_suffixes` (a.k.a. `AddMetricSuffixes`) **enabled** or this dashboard and the alert pack go silently blank."
              }
            }
          }
        }
      },
      "hlth-ingest": {
        "kind": "Panel",
        "spec": {
          "id": 501,
          "title": "Events ingested",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(rate(sf2loki_events_ingested_total{job=\"$job\"}[$__rate_interval]))",
                        "legendFormat": "",
                        "range": true,
                        "instant": false,
                        "datasource": {
                          "type": "prometheus",
                          "uid": "${ds_prom}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "cps",
                  "color": {
                    "mode": "fixed"
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
      "hlth-lag": {
        "kind": "Panel",
        "spec": {
          "id": 502,
          "title": "Ingest lag p95",
          "description": "",
          "links": [],
