          "vizConfig": {
            "group": "timeseries",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "cps",
                  "color": {
                    "mode": "palette-classic"
                  },
                  "custom": {
                    "drawStyle": "line",
                    "lineInterpolation": "smooth",
                    "lineWidth": 1,
                    "fillOpacity": 20,
                    "gradientMode": "opacity",
                    "showPoints": "never",
                    "spanNulls": true,
                    "axisPlacement": "auto",
                    "scaleDistribution": {
                      "type": "linear"
                    },
                    "stacking": {
                      "mode": "normal",
                      "group": "A"
                    }
                  }
                },
                "overrides": []
              },
              "options": {
                "legend": {
                  "displayMode": "list",
                  "placement": "bottom",
                  "showLegend": true,
                  "calcs": [
                    "sum"
                  ]
                },
                "tooltip": {
                  "mode": "multi",
                  "sort": "desc"
                }
              }
            }
          }
        }
      },
