{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "sf2loki-apex-performance",
    "annotations": {
      "grafana.app/folder": "sf2loki"
    }
  },
  "spec": {
    "title": "sf2loki \u00b7 Apex & Performance",
    "description": "Apex callouts and Salesforce request performance from EventLogFile.",
    "tags": [
      "sf2loki",
      "salesforce",
      "performance"
    ],
    "editable": true,
    "preload": false,
    "cursorSync": "Off",
    "liveNow": false,
    "links": [],
    "annotations": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "timezone": "browser",
      "autoRefresh": "",
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0,
      "autoRefreshIntervals": [
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "1d"
      ]
    },
    "variables": [
      {
        "kind": "CustomVariable",
        "spec": {
          "name": "job",
          "label": "Job",
          "query": "sf2loki",
          "current": {
            "text": "sf2loki",
            "value": "sf2loki"
          },
          "options": [
            {
              "text": "sf2loki",
              "value": "sf2loki",
              "selected": true
            }
          ],
          "hide": "dontHide",
          "multi": false,
          "includeAll": false,
          "allValue": "",
          "skipUrlSync": false,
          "allowCustomValue": true
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "name": "ds_loki",
          "label": "Loki datasource",
          "pluginId": "loki",
          "current": {
            "text": "",
            "value": ""
          },
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": false,
          "includeAll": false,
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": ""
        }
      }
    ],
    "elements": {
      "apex-header": {
        "kind": "Panel",
        "spec": {
          "id": 400,
          "title": "",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "text",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "mode": "markdown",
                "content": "## Apex & Performance\nApex callouts, request performance (run time, CPU, DB time) and report execution from EventLogFile. Percentiles use `unwrap` over the numeric CSV fields."
              }
            }
          }
        }
      },
      "apx-callouts": {
        "kind": "Panel",
        "spec": {
          "id": 401,
          "title": "Apex callouts",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"ApexCallout\", source=\"eventlogfile\"}[$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "fixed"
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
      "apx-errrate": {
        "kind": "Panel",
        "spec": {
          "id": 402,
          "title": "Callout error rate",
          "description": "ApexCallout with SUCCESS=0 as a share of all callouts.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"ApexCallout\", source=\"eventlogfile\"} | json s=\"SUCCESS\" | s=\"0\" [$__range])) / sum(count_over_time({job=\"$job\", event_type=\"ApexCallout\", source=\"eventlogfile\"}[$__range])) * 100",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "percent",
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": null
                      },
                      {
                        "color": "yellow",
                        "value": 2
                      },
                      {
                        "color": "red",
                        "value": 10
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
