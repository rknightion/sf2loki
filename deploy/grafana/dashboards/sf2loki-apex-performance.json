      "apx-success-ts": {
        "kind": "Panel",
        "spec": {
          "id": 405,
          "title": "Apex callout outcomes",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum by (SUCCESS)(rate({job=\"$job\", event_type=\"ApexCallout\", source=\"eventlogfile\"} | json SUCCESS=\"SUCCESS\" [$__auto]))",
                        "legendFormat": "success={{SUCCESS}}",
                        "queryType": "range",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
