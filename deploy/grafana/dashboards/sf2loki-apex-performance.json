      "apx-report-rows": {
        "kind": "Panel",
        "spec": {
          "id": 411,
          "title": "Report row count avg",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "avg_over_time({job=\"$job\", event_type=\"Report\", source=\"eventlogfile\"} | json rc=\"ROW_COUNT\" | rc!=\"\" | unwrap rc [$__auto]) by (event_type)",
