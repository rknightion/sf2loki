{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "sf2loki-security-access",
    "annotations": {
      "grafana.app/folder": "sf2loki"
    }
  },
  "spec": {
    "title": "sf2loki \u00b7 Security & Access",
    "description": "Salesforce login/logout security monitoring from EventLogFile and Pub/Sub streaming.",
    "tags": [
      "sf2loki",
      "salesforce",
      "security"
    ],
    "editable": true,
    "preload": false,
    "cursorSync": "Off",
    "liveNow": false,
    "links": [],
    "annotations": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "timezone": "browser",
      "autoRefresh": "",
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0,
      "autoRefreshIntervals": [
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "1d"
      ]
    },
    "variables": [
      {
        "kind": "CustomVariable",
        "spec": {
          "name": "job",
          "label": "Job",
          "query": "sf2loki",
          "current": {
            "text": "sf2loki",
            "value": "sf2loki"
          },
          "options": [
            {
              "text": "sf2loki",
              "value": "sf2loki",
              "selected": true
            }
          ],
          "hide": "dontHide",
          "multi": false,
          "includeAll": false,
          "allValue": "",
          "skipUrlSync": false,
          "allowCustomValue": true
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "name": "ds_loki",
          "label": "Loki datasource",
          "pluginId": "loki",
          "current": {
            "text": "",
            "value": ""
          },
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": false,
          "includeAll": false,
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": ""
        }
      }
    ],
    "elements": {
      "sec-header": {
        "kind": "Panel",
        "spec": {
          "id": 200,
          "title": "",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "text",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "mode": "markdown",
                "content": "## Salesforce Security & Access\nLogin / logout activity from **EventLogFile** (`Login`) and real-time **Pub/Sub** (`LoginEventStream`, `LogoutEventStream`). Watch for failed-login spikes, unfamiliar source IPs / countries, and weak TLS."
              }
            }
          }
        }
      },
      "sec-logins": {
        "kind": "Panel",
        "spec": {
          "id": 201,
          "title": "Login attempts",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"Login\", source=\"eventlogfile\"}[$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "fixed"
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
      "sec-failures": {
        "kind": "Panel",
        "spec": {
          "id": 202,
          "title": "Failed logins",
          "description": "Logins with LOGIN_STATUS other than LOGIN_NO_ERROR.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"Login\", source=\"eventlogfile\"} | json s=\"LOGIN_STATUS\" | s!=\"LOGIN_NO_ERROR\" | s!=\"\" [$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": null
                      },
                      {
                        "color": "yellow",
                        "value": 1
                      },
                      {
                        "color": "red",
                        "value": 50
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
