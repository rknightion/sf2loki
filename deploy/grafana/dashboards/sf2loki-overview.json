              },
              "options": {
                "mode": "markdown",
                "content": "## Salesforce Event Monitoring \u2014 Overview\nAll ingested Salesforce events flowing through **sf2loki** into Loki, across every source (`eventlogfile`, `pubsub`). Use the **Security & Access**, **API & Integration**, and **Apex & Performance** dashboards to drill in, and **Connector Health** for pipeline reliability."
              }
            }
          }
        }
      },
      "ov-total": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Events ingested",
          "description": "Total events over the selected range.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\"}[$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "fixed"
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
