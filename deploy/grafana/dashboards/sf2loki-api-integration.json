                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum by (API_FAMILY)(rate({job=\"$job\", event_type=\"ApiTotalUsage\", source=\"eventlogfile\"} | json API_FAMILY=\"API_FAMILY\" [$__auto]))",
                        "legendFormat": "{{API_FAMILY}}",
                        "queryType": "range",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
