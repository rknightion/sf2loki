{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "sf2loki-api-integration",
    "annotations": {
      "grafana.app/folder": "sf2loki"
    }
  },
  "spec": {
    "title": "sf2loki \u00b7 API & Integration",
    "description": "Salesforce API consumption and integration monitoring.",
    "tags": [
      "sf2loki",
      "salesforce",
      "api"
    ],
    "editable": true,
    "preload": false,
    "cursorSync": "Off",
    "liveNow": false,
    "links": [],
    "annotations": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "timezone": "browser",
      "autoRefresh": "",
      "hideTimepicker": false,
      "fiscalYearStartMonth": 0,
      "autoRefreshIntervals": [
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "1d"
      ]
    },
    "variables": [
      {
        "kind": "CustomVariable",
        "spec": {
          "name": "job",
          "label": "Job",
          "query": "sf2loki",
          "current": {
            "text": "sf2loki",
            "value": "sf2loki"
          },
          "options": [
            {
              "text": "sf2loki",
              "value": "sf2loki",
              "selected": true
            }
          ],
          "hide": "dontHide",
          "multi": false,
          "includeAll": false,
          "allValue": "",
          "skipUrlSync": false,
          "allowCustomValue": true
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "name": "ds_loki",
          "label": "Loki datasource",
          "pluginId": "loki",
          "current": {
            "text": "",
            "value": ""
          },
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": false,
          "includeAll": false,
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": ""
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "name": "ds_prom",
          "label": "Prometheus datasource",
          "pluginId": "prometheus",
          "current": {
            "text": "",
            "value": ""
          },
          "hide": "dontHide",
          "skipUrlSync": false,
          "multi": false,
          "includeAll": false,
          "options": [],
          "refresh": "onDashboardLoad",
          "regex": ""
        }
      }
    ],
    "elements": {
      "api-header": {
        "kind": "Panel",
        "spec": {
          "id": 300,
          "title": "",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "text",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "mode": "markdown",
                "content": "## Salesforce API & Integration\nAPI consumption from **EventLogFile** (`ApiTotalUsage`, `RestApi`, `BulkApi2`, `CompositeApi`) and real-time `ApiEventStream`. The org API-limit gauge is sourced from the connector's own OTLP metrics (needs the Prometheus datasource)."
              }
            }
          }
        }
      },
      "api-total": {
        "kind": "Panel",
        "spec": {
          "id": 301,
          "title": "API calls (total)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"ApiTotalUsage\", source=\"eventlogfile\"}[$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "fixed"
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
