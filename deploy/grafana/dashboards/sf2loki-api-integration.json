            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "color": {
                    "mode": "palette-classic"
                  }
                },
                "overrides": []
              },
              "options": {
                "showHeader": true,
                "cellHeight": "sm",
                "footer": {
                  "show": false,
                  "reducer": [
