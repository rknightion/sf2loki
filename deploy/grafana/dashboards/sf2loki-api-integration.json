                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"RestApi\", source=\"eventlogfile\"}[$__range]))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
