      "api-top-resources": {
        "kind": "Panel",
        "spec": {
          "id": 307,
          "title": "Top API consumers",
          "description": "Busiest API users (per-endpoint resource breakdown exceeds Loki's series cap at this cardinality).",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "topk(15, sum by (USER_NAME)(count_over_time({job=\"$job\", event_type=\"ApiTotalUsage\", source=\"eventlogfile\"} | json USER_NAME=\"USER_NAME\" | USER_NAME!=\"\" [$__range])))",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
