      "api-resources": {
        "kind": "Panel",
        "spec": {
          "id": 303,
          "title": "REST error rate",
          "description": "Share of RestApi calls with a 4xx/5xx STATUS_CODE.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "sum(count_over_time({job=\"$job\", event_type=\"RestApi\", source=\"eventlogfile\"} | json sc=\"STATUS_CODE\" | sc=~\"4..|5..\" [$__range])) / sum(count_over_time({job=\"$job\", event_type=\"RestApi\", source=\"eventlogfile\"}[$__range])) * 100",
                        "legendFormat": "",
                        "queryType": "instant",
                        "datasource": {
                          "type": "loki",
                          "uid": "${ds_loki}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "percent",
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": null
                      },
                      {
                        "color": "yellow",
                        "value": 1
                      },
                      {
                        "color": "red",
                        "value": 5
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
      "api-limit": {
        "kind": "Panel",
        "spec": {
          "id": 304,
          "title": "Min API limit remaining",
          "description": "Lowest headroom across all Salesforce org limits (from OTLP metrics).",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "refId": "A",
                    "query": {
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "version": "v0",
                      "spec": {
                        "expr": "min(sf2loki_salesforce_limit_remaining{job=\"$job\"} / sf2loki_salesforce_limit_max{job=\"$job\"}) * 100",
                        "legendFormat": "",
                        "range": false,
                        "instant": true,
                        "datasource": {
                          "type": "prometheus",
                          "uid": "${ds_prom}"
                        }
                      }
                    }
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "vizConfig": {
            "group": "stat",
            "kind": "VizConfig",
            "version": "",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "percent",
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "red",
                        "value": null
                      },
                      {
                        "color": "yellow",
                        "value": 10
                      },
                      {
                        "color": "green",
                        "value": 25
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "textMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "wideLayout": true,
                "showPercentChange": false,
                "percentChangeColorMode": "standard"
              }
            }
          }
        }
      },
      "api-family-ts": {
        "kind": "Panel",
        "spec": {
          "id": 305,
          "title": "API usage rate by family",
          "description": "",
